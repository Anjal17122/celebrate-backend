input FiltersInput {
  status: SupportTicketStatus
  search: String
  page: Int
  limit: Int
}

input SingleUserSupportTicketsInput {
  userId: ID!
  filters: FiltersInput
}

type PaginatedSupportTickets {
  tickets: [SupportTicket!]!
  docsCount: Int!
  totalPages: Int!
  currentPage: Int!
}

type PaginatedUsers {
  users: [User!]!
  docsCount: Int!
  totalPages: Int!
  currentPage: Int!
}

type PaginatedUsersWithLatestTicket {
  users: [UserWithLatestTicket!]!
  docsCount: Int!
  totalPages: Int!
  currentPage: Int!
}

