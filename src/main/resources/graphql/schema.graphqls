enum SupportTicketStatus {
  open
  inProgress
  closed
}

type User {
  _id: ID!
  name: String!
  email: String!
  phone: String
  isActive: Boolean
  userType: String
  phoneIsVerified: Boolean
  emailIsVerified: Boolean
  password: String
  status: String
  statusReason: String
  lastLogin: Date
  isOrderNotification: Boolean
  isOfferNotification: Boolean
  createdAt: String
  updatedAt: String
  addresses: [Address!]
  notificationToken: String
  favourite: [String!]
  notes: String
}

type UserWithLatestTicket {
  _id: ID!
  name: String!
  email: String!
  phone: String
  isActive: Boolean
  userType: String
  latestTicket: SupportTicket
}

type SupportTicket {
  _id: ID!
  title: String!
  description: String!
  status: String!
  category: String!
  orderId: String
  otherDetails: String
  createdAt: String!
  updatedAt: String!
  user: User
  userType: String
}

input SupportTicketInput {
  title: String!
  description: String!
  category: String!
  orderId: String
  otherDetails: String
  userType: String!
}

input UpdateSupportTicketInput {
  ticketId: ID!
  status: SupportTicketStatus!
}

