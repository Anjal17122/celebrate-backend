type Message {
  _id: ID!
  senderType: String!
  content: String!
  isRead: Boolean!
  ticket: ID!
  createdAt: String!
  updatedAt: String!
}

input MessageInput {
  content: String!
  ticket: ID!
}

type TicketMessageResponse {
  messages: [Message!]!
  ticket: SupportTicket!
  page: Int!
  totalPages: Int!
  docsCount: Int!
}

input TicketMessagesInput {
  ticket: ID!
  page: Int
  limit: Int
}

scalar Date

scalar JSON

type UploadResult {
  imageUrl: String!
}

type ShopType {
  _id: ID!
  image: String
  name: String
  slug: String
  isActive: Boolean
  createdAt: String
  updatedAt: String
  deletedAt: String
}

type AllShopTypeResponse {
  _id: ID!
  image: String
  name: String
  slug: String
}

type AllShopTypes {
  data: [AllShopTypeResponse]
}

type ShopTypePagination {
  data: [ShopType]
  total: Int
  page: Int
  pageSize: Int
  totalPages: Int
  hasNextPage: Boolean
  hasPrevPage: Boolean
}

type DeleteResult {
  success: Boolean!
  message: String!
}

enum DeleteTypeEnum {
  SOFT
  HARD
}

enum OTPTypeEnum {
  EMAIL
  PHONE
}

enum UserTypeEnum {
  RIDER
  STORE
}

enum OrderTypeEnum {
  DELIVERY
  PICKUP
}

enum PaymentMethodEnum {
  COD
  PAYPAL
  STRIPE
}

type Location {
  location: Point
  deliveryAddress: String
}

type Address {
  _id: ID!
  location: Point
  deliveryAddress: String!
  details: String
  label: String!
  selected: Boolean
}

type OrderAddress {
  location: Point
  deliveryAddress: String!
  details: String
  label: String!
  id: String
}

type PublicAccess {
  excellence: String!
  topgun: String!
  experience: String!
  skydiver: String!
  rider: String!
  haha: String!
  hehe: String!
  huhu: String!
  yoyo: String!
  turu: String!
}

